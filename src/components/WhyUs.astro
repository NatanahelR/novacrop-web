---
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
---

<section id="why" class="py-28 bg-white relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Aerial field visual -->
      <div data-aos="fade-right" class="relative order-2 lg:order-1">
        <div class="relative rounded-3xl overflow-hidden bg-[#1C3D2E] aspect-[4/3]">
          <!-- Animated drone-view field -->
          <svg class="w-full h-full" viewBox="0 0 480 360" preserveAspectRatio="xMidYMid slice">
            <defs>
              <linearGradient id="fieldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#1C3D2E"/>
                <stop offset="100%" stop-color="#2D5A3D"/>
              </linearGradient>
              <linearGradient id="waterGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" stop-color="#3B55C0" stop-opacity="0.8"/>
                <stop offset="100%" stop-color="#3B55C0" stop-opacity="0.2"/>
              </linearGradient>
            </defs>

            <rect width="480" height="360" fill="url(#fieldGrad)"/>

            <!-- Crop rows -->
            {Array.from({ length: 16 }).map((_, i) => (
              <rect x="40" y={20 + i * 20} width="400" height="10" rx="2" fill="#4A8C5C" opacity={0.4 + (i % 3) * 0.15}/>
            ))}

            <!-- Irrigation lines -->
            {Array.from({ length: 5 }).map((_, i) => (
              <rect x={40 + i * 92} y="20" width="3" height="320" rx="1.5" fill="url(#waterGrad)"/>
            ))}

            <!-- Animated water flow -->
            {Array.from({ length: 5 }).map((_, i) => (
              <circle cx={40 + i * 92} cy="40" r="3" fill="#5B75D0" opacity="0.9">
                <animate attributeName="cy" values="20;340;20" dur={`${2 + i * 0.4}s`} repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0;0.9;0" dur={`${2 + i * 0.4}s`} repeatCount="indefinite"/>
              </circle>
            ))}

            <!-- Paraguay label -->
            <text x="240" y="340" text-anchor="middle" fill="white" font-size="11" opacity="0.4" font-family="Inter, sans-serif" font-weight="600" letter-spacing="3">
              PARAGUAY
            </text>
          </svg>

          <!-- Overlay label -->
          <div class="absolute top-4 left-4 bg-black/40 backdrop-blur-sm rounded-xl px-3 py-2 text-white text-xs font-semibold">
            Vista aérea — Campo bajo riego
          </div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="order-1 lg:order-2">
        <span data-aos="fade-down" class="inline-block text-[#3B55C0] text-xs font-semibold tracking-widest uppercase mb-4">
          {tr.why.tag}
        </span>
        <h2 data-aos="fade-up" class="text-3xl md:text-5xl font-extrabold text-[#1C3D2E] mb-10 leading-tight">
          {tr.why.headline}
        </h2>

        <div class="space-y-6">
          {tr.why.items.map((item, i) => (
            <div
              data-aos="fade-left"
              data-aos-delay={i * 100}
              class="flex gap-5 group"
            >
              <div class="flex-shrink-0 mt-1">
                <div class="w-8 h-8 rounded-full border-2 border-[#3B55C0] flex items-center justify-center text-[#3B55C0] font-bold text-sm group-hover:bg-[#3B55C0] group-hover:text-white transition-all">
                  {i + 1}
                </div>
              </div>
              <div>
                <h3 class="text-base font-bold text-[#1C3D2E] mb-1">{item.title}</h3>
                <p class="text-sm text-gray-500 leading-relaxed">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
