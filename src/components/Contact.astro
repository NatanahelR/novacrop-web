---
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const form = tr.contact.form;

// REEMPLAZAR con el endpoint de Formspree cuando el cliente defina el email:
// 1. Crear cuenta en formspree.io
// 2. Crear un form y copiar el endpoint: https://formspree.io/f/XXXXXXXX
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/PLACEHOLDER';
---

<section id="contact" class="py-28 bg-[#1C3D2E] relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 field-grid opacity-[0.04] pointer-events-none"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-[#3B55C0]/10 rounded-full -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto px-6">
    <div class="text-center mb-14">
      <span data-aos="fade-down" class="inline-block text-[#5B75D0] text-xs font-semibold tracking-widest uppercase mb-4">
        {tr.contact.tag}
      </span>
      <h2 data-aos="fade-up" class="text-3xl md:text-5xl font-extrabold text-white mb-5 leading-tight">
        {tr.contact.headline}
      </h2>
      <p data-aos="fade-up" data-aos-delay="100" class="text-lg text-white/60 max-w-xl mx-auto leading-relaxed">
        {tr.contact.description}
      </p>
    </div>

    <div data-aos="fade-up" data-aos-delay="200" class="bg-white/5 backdrop-blur-sm rounded-3xl p-8 md:p-12 border border-white/10">
      <form
        id="contact-form"
        action={FORMSPREE_ENDPOINT}
        method="POST"
        class="grid grid-cols-1 md:grid-cols-2 gap-6"
      >
        <!-- Name -->
        <div class="md:col-span-1">
          <label class="block text-sm font-medium text-white/70 mb-2">{form.name}</label>
          <input
            type="text"
            name="name"
            required
            class="w-full bg-white/8 border border-white/15 rounded-xl px-4 py-3.5 text-white placeholder-white/30 focus:outline-none focus:border-[#3B55C0] focus:bg-white/12 transition-all"
            placeholder="Juan García"
          />
        </div>

        <!-- Email -->
        <div class="md:col-span-1">
          <label class="block text-sm font-medium text-white/70 mb-2">{form.email}</label>
          <input
            type="email"
            name="email"
            required
            class="w-full bg-white/8 border border-white/15 rounded-xl px-4 py-3.5 text-white placeholder-white/30 focus:outline-none focus:border-[#3B55C0] focus:bg-white/12 transition-all"
            placeholder="juan@empresa.com"
          />
        </div>

        <!-- Company -->
        <div class="md:col-span-1">
          <label class="block text-sm font-medium text-white/70 mb-2">{form.company}</label>
          <input
            type="text"
            name="company"
            class="w-full bg-white/8 border border-white/15 rounded-xl px-4 py-3.5 text-white placeholder-white/30 focus:outline-none focus:border-[#3B55C0] focus:bg-white/12 transition-all"
            placeholder="Agro S.A."
          />
        </div>

        <!-- Role -->
        <div class="md:col-span-1">
          <label class="block text-sm font-medium text-white/70 mb-2">{form.role}</label>
          <select
            name="role"
            class="w-full bg-[#1C3D2E] border border-white/15 rounded-xl px-4 py-3.5 text-white focus:outline-none focus:border-[#3B55C0] transition-all appearance-none"
          >
            {form.role_options.map(opt => (
              <option value={opt}>{opt}</option>
            ))}
          </select>
        </div>

        <!-- Message -->
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-white/70 mb-2">{form.message}</label>
          <textarea
            name="message"
            rows="4"
            class="w-full bg-white/8 border border-white/15 rounded-xl px-4 py-3.5 text-white placeholder-white/30 focus:outline-none focus:border-[#3B55C0] focus:bg-white/12 transition-all resize-none"
            placeholder="Contanos sobre tu campo, proyecto o consulta..."
          ></textarea>
        </div>

        <!-- Honeypot anti-spam -->
        <input type="text" name="_gotcha" class="hidden" />

        <!-- Submit -->
        <div class="md:col-span-2">
          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-[#3B55C0] hover:bg-[#5B75D0] text-white font-semibold py-4 rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-[#3B55C0]/30 disabled:opacity-60 disabled:cursor-not-allowed"
          >
            <span id="btn-text">{form.submit}</span>
          </button>

          <p id="form-success" class="hidden mt-4 text-center text-green-400 font-medium">{form.success}</p>
          <p id="form-error" class="hidden mt-4 text-center text-red-400 font-medium">{form.error}</p>
        </div>
      </form>
    </div>
  </div>
</section>

<script define:vars={{ sendingText: form.sending, submitText: form.submit, successText: form.success, errorText: form.error }}>
  const form = document.getElementById('contact-form');
  const btn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn || !btnText) return;

    btn.setAttribute('disabled', 'true');
    btnText.textContent = sendingText;
    successEl?.classList.add('hidden');
    errorEl?.classList.add('hidden');

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        successEl?.classList.remove('hidden');
      } else {
        errorEl?.classList.remove('hidden');
      }
    } catch {
      errorEl?.classList.remove('hidden');
    } finally {
      btn.removeAttribute('disabled');
      btnText.textContent = submitText;
    }
  });
</script>
