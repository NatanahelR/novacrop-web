---
import type { Lang } from '../i18n/index';
import { t } from '../i18n/index';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);

const icons: Record<string, string> = {
  shield: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>`,
  'trending-up': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/>`,
  calendar: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>`,
  'dollar-sign': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
};
---

<section id="benefits" class="py-28 bg-[#F7FAF8] relative overflow-hidden">
  <div class="absolute top-0 right-0 w-96 h-96 bg-[#3B55C0]/5 rounded-full -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-64 h-64 bg-[#1C3D2E]/5 rounded-full translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span data-aos="fade-down" class="inline-block text-[#3B55C0] text-xs font-semibold tracking-widest uppercase mb-4">
        {tr.benefits.tag}
      </span>
      <h2 data-aos="fade-up" class="text-3xl md:text-5xl font-extrabold text-[#1C3D2E] leading-tight">
        {tr.benefits.headline}
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {tr.benefits.items.map((item, i) => (
        <div
          data-aos="fade-up"
          data-aos-delay={i * 100}
          class="group bg-white rounded-2xl p-8 border border-[#1C3D2E]/8 hover:border-[#3B55C0]/40 hover:shadow-xl hover:shadow-[#3B55C0]/10 transition-all duration-300 hover:-translate-y-1"
        >
          <div class="w-12 h-12 rounded-xl bg-[#1C3D2E] group-hover:bg-[#3B55C0] transition-colors flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[item.icon]} />
          </div>
          <h3 class="text-lg font-bold text-[#1C3D2E] mb-3 group-hover:text-[#3B55C0] transition-colors">
            {item.title}
          </h3>
          <p class="text-sm text-gray-500 leading-relaxed">
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
